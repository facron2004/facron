{% extends "base_new.html.j2" %}

{% block title %}Dashboard · Review Scraper{% endblock %}

{% block content %}
<div class="page-head">
  <h1>评论抓取任务中心</h1>
  <p>创建、监控并导出商品评论抓取任务。当前系统状态与近期活动一览。</p>
</div>

<!-- 状态指标卡 -->
<div class="grid grid-4" style="margin-bottom: 24px;">
  <article class="metric-card">
    <span class="metric-label">系统状态</span>
    <span class="metric-value" id="systemStatus">在线</span>
    <span class="metric-note">任务调度 · 导出 · WebSocket</span>
  </article>
  <article class="metric-card">
    <span class="metric-label">导出格式</span>
    <span class="metric-value">CSV · XLSX · JSON</span>
    <span class="metric-note">完成后自动生成</span>
  </article>
  <article class="metric-card">
    <span class="metric-label">进度更新</span>
    <span class="metric-value">轮询 + 实时</span>
    <span class="metric-note">WebSocket 自动推送</span>
  </article>
  <article class="metric-card">
    <span class="metric-label">抓取引擎</span>
    <span class="metric-value">Playwright</span>
    <span class="metric-note">支持有头 / 无头模式</span>
  </article>
</div>

<!-- 数据统计 -->
<div class="grid grid-4" style="margin-bottom: 24px;">
  <article class="metric-card">
    <span class="metric-label">任务总数</span>
    <span class="metric-value" id="totalTasks">--</span>
    <span class="metric-note">全部历史任务</span>
  </article>
  <article class="metric-card">
    <span class="metric-label">评论总数</span>
    <span class="metric-value" id="totalReviews">--</span>
    <span class="metric-note">累计抓取评论</span>
  </article>
  <article class="metric-card">
    <span class="metric-label">进行中</span>
    <span class="metric-value" id="activeTasks">--</span>
    <span class="metric-note">运行 + 队列中</span>
  </article>
  <article class="metric-card">
    <span class="metric-label">成功率</span>
    <span class="metric-value" id="successRate">--</span>
    <span class="metric-note">已完成 / 全部</span>
  </article>
</div>

<!-- 最近活动 -->
<div class="card" style="margin-bottom: 24px;">
  <div class="card-header">
    <h2>最近活动</h2>
    <a href="/tasks" class="btn btn-ghost btn-sm">查看全部</a>
  </div>
  <div id="recentTasks">
    <div class="loading-block">加载中...</div>
  </div>
</div>

<!-- 快捷操作 -->
<div style="display: flex; gap: 12px; flex-wrap: wrap;">
  <a href="/reviews" class="btn btn-primary">前往抓取页面</a>
  <a href="/tasks" class="btn btn-secondary">查看任务面板</a>
  <a href="/analysis" class="btn btn-secondary">前往分析页</a>
</div>
{% endblock %}

{% block head %}
<style>
  .task-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding: 14px 0;
    border-bottom: 1px solid var(--border-subtle);
  }
  .task-item:last-child { border-bottom: none; }
  .task-item:hover { background: var(--bg-hover); margin: 0 -20px; padding: 14px 20px; border-radius: var(--radius-sm); }
  .task-item-info { flex: 1; min-width: 0; }
  .task-item-row1 { display: flex; align-items: center; gap: 10px; margin-bottom: 4px; }
  .task-item-id { font-family: var(--font-mono); font-size: 12px; color: var(--text-subtle); }
  .task-item-meta { font-size: 12px; color: var(--text-muted); }
  .task-item-time { font-size: 12px; color: var(--text-muted); white-space: nowrap; }
</style>
{% endblock %}

{% block scripts %}
<script>
  async function loadDashboardData() {
    try {
      const res = await fetch('/api/reviews/tmall/tasks?limit=50');
      const tasks = await res.json();

      const totalTasks = tasks.length;
      const totalReviews = tasks.reduce((sum, t) => sum + (t.review_count || 0), 0);
      const activeTasks = tasks.filter(t => t.status === 'running' || t.status === 'queued').length;
      const doneTasks = tasks.filter(t => t.status === 'done').length;
      const successRate = totalTasks > 0 ? Math.round((doneTasks / totalTasks) * 100) : 0;

      animateValue('totalTasks', 0, totalTasks, 700);
      animateValue('totalReviews', 0, totalReviews, 1000);
      animateValue('activeTasks', 0, activeTasks, 600);
      animateValue('successRate', 0, successRate, 800, '%');

      const recentTasks = tasks.slice(0, 6);
      const el = document.getElementById('recentTasks');
      if (recentTasks.length === 0) {
        el.innerHTML = '<div class="loading-block">暂无任务记录，前往抓取页面创建第一个任务。</div>';
        return;
      }

      el.innerHTML = recentTasks.map(task => `
        <div class="task-item">
          <div class="task-item-info">
            <div class="task-item-row1">
              <span class="status status-${task.status}">${task.status}</span>
              <span class="task-item-id">${task.item_id || 'N/A'}</span>
            </div>
            <div class="task-item-meta">${task.review_count || 0} 条评论 · ${task.page_count || 0} 页</div>
          </div>
          <div class="task-item-time">
            ${task.created_at ? new Date(task.created_at).toLocaleString('zh-CN', {
              month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit'
            }) : ''}
          </div>
        </div>
      `).join('');
    } catch (err) {
      console.error('Failed to load dashboard:', err);
      document.getElementById('recentTasks').innerHTML =
        '<div class="loading-block">数据加载失败，请稍后重试。</div>';
    }
  }

  function animateValue(id, start, end, duration, suffix = '') {
    const elem = document.getElementById(id);
    if (!elem) return;
    const range = end - start;
    const stepTime = 16;
    const steps = Math.max(1, Math.floor(duration / stepTime));
    const increment = range / steps;
    let current = start;
    let count = 0;
    const timer = setInterval(() => {
      current += increment;
      count++;
      if (count >= steps) { current = end; clearInterval(timer); }
      elem.textContent = Math.round(current) + suffix;
    }, stepTime);
  }

  loadDashboardData();
  setInterval(loadDashboardData, 10000);
</script>
{% endblock %}
