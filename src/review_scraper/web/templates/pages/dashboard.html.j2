{% extends "base.html.j2" %}
{% block title %}Dashboard · Review Scraper{% endblock %}
{% block content %}
<section class="hero">
  <h1 id="title">Amazon关键词竞品监控系统</h1>
  <p id="subtitle">正在加载后端数据</p>
  <div class="chips" id="runtimeChips"></div>
</section>

<section class="section">
  <h2 class="section-title">运行概览</h2>
  <div class="metrics" id="metrics">
    <div class="loading">加载中...</div>
  </div>
</section>

<section class="section">
  <h2 class="section-title">后端能力模块</h2>
  <div class="grid-3" id="modules"></div>
</section>

<section class="section">
  <h2 class="section-title">数据流转链路</h2>
  <div class="steps" id="pipeline"></div>
</section>

<section class="section">
  <h2 class="section-title">关键词结果卡片</h2>
  <div class="keyword-grid" id="keywords"></div>
</section>

<section class="section">
  <h2 class="section-title">真实抓取验证</h2>
  <div class="validation" id="validation"></div>
</section>
{% endblock %}
{% block head %}
<script>
  function tagClass(status) {
    if (status === "ready") return "badge ok";
    if (status === "warn") return "badge warn";
    return "badge bad";
  }

  function fmtEventCounter(counter) {
    const entries = Object.entries(counter || {});
    if (!entries.length) return "无事件";
    return entries.map(([k, v]) => `${k}: ${v}`).join(" · ");
  }

  async function loadOverview() {
    const res = await fetch("/api/frontend/overview");
    if (!res.ok) throw new Error(`overview failed: ${res.status}`);
    return res.json();
  }

  function render(data) {
    document.getElementById("title").textContent = data.title;
    document.getElementById("subtitle").textContent = data.subtitle;

    const chips = document.getElementById("runtimeChips");
    chips.innerHTML = `
      <span class="chip">collector: ${data.runtime.collector}</span>
      <span class="chip">top_n: ${data.runtime.top_n}</span>
      <span class="chip">bsr_top_n: ${data.runtime.bsr_top_n}</span>
      <span class="chip">push: ${data.runtime.push_channel}</span>
      <span class="chip">retry: ${data.runtime.max_attempts}x</span>
    `;

    const metrics = document.getElementById("metrics");
    metrics.innerHTML = `
      <article class="metric">
        <div class="label">最近运行日期</div>
        <div class="value">${data.latest_run.snapshot_date || "-"}</div>
      </article>
      <article class="metric">
        <div class="label">关键词数量</div>
        <div class="value">${data.latest_run.keyword_count}</div>
      </article>
      <article class="metric">
        <div class="label">触发推送数</div>
        <div class="value">${data.latest_run.push_count}</div>
      </article>
      <article class="metric">
        <div class="label">失败关键词数</div>
        <div class="value">${data.latest_run.failed_count}</div>
      </article>
    `;

    const modules = document.getElementById("modules");
    modules.innerHTML = data.modules
      .map(
        (m) => `
          <article class="card">
            <h3>${m.name} <span class="${tagClass(m.status)}">${m.status}</span></h3>
            <div class="small">${m.desc}</div>
          </article>
        `
      )
      .join("");

    const pipeline = document.getElementById("pipeline");
    pipeline.innerHTML = data.pipeline_steps.map((step) => `<div class="step">${step}</div>`).join("");

    const keywords = document.getElementById("keywords");
    keywords.innerHTML = (data.keyword_summaries || [])
      .map(
        (item) => `
          <article class="keyword-card">
            <h4>${item.keyword}</h4>
            <div class="keyword-meta">
              <span class="pill">事件数 ${item.event_count}</span>
              <span class="pill">推送 ${item.push_status}</span>
              <span class="pill">折扣数 ${item.metrics.discount_asin_count ?? 0}</span>
            </div>
            <ul class="list">
              <li>${fmtEventCounter(item.event_counter)}</li>
              <li>趋势: ${item.analysis.market_trend}</li>
              <li>价格: ${item.analysis.price_competition}</li>
            </ul>
          </article>
        `
      )
      .join("");

    const validation = document.getElementById("validation");
    if (!data.real_validation.available) {
      validation.innerHTML = `<div class="badge warn">未加载真实验证</div><p class="small">${data.real_validation.message}</p>`;
      return;
    }
    validation.innerHTML = `
      <p class="small">文件: ${data.real_validation.file_path}</p>
      <p class="small">生成时间: ${data.real_validation.generated_at || "-"}</p>
      ${data.real_validation.keywords
        .map(
          (k) => `
            <div class="validation-keyword" style="border:1px dashed #cdd8eb;border-radius:12px;padding:10px;margin-top:10px">
              <strong>${k.keyword}</strong>
              <div class="small">Top Count: ${k.top_count}</div>
              <ul class="list">
                ${k.sample_items
                  .map(
                    (it) => `
                      <li>
                        <span class="asin">${it.asin}</span>
                        | ${it.title || "N/A"}
                        | ${it.bsr || "N/A"}
                        | <a href="${it.url}" target="_blank" rel="noreferrer">Amazon链接</a>
                      </li>
                    `
                  )
                  .join("")}
              </ul>
            </div>
          `
        )
        .join("")}
    `;
  }

  loadOverview().then(render).catch((err) => {
    document.getElementById("title").textContent = "加载失败";
    document.getElementById("subtitle").textContent = err.message;
  });
</script>
{% endblock %}
